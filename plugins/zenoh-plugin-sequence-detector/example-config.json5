{
  plugins: {
    sequence_detector: {
      selector: "iot/devices/*",
      stats_interval_secs: 10,
      stats_key: "monitoring/sequence_stats"
    }
  }
}

// Example 3: Multiple Specific Patterns
// Note: The plugin currently supports one selector. To monitor multiple
// patterns, either:
//   - Use a wildcard that covers all (e.g., "sensors/**")
//   - Run multiple zenohd instances with different configs
//   - Use key expression intersections (e.g., "sensors/*")
{
  plugins: {
    sequence_detector: {
      selector: "sensors/*",  // Matches sensors/temp, sensors/pressure, etc.
      stats_interval_secs: 60
    }
  }
}

// Example 4: Production Monitoring Setup
{
  plugins: {
    sequence_detector: {
      selector: "prod/**/metrics",
      stats_interval_secs: 300,  // 5 minutes
      stats_key: "admin/monitoring/sequence_detector/stats"
    }
  }
}

// Example 5: Development/Testing Setup
{
  plugins: {
    sequence_detector: {
      selector: "test/sequenced/**",
      stats_interval_secs: 5,  // Very frequent for quick feedback
      stats_key: "test/stats"
    }
  }
}

// Example 6: Stats-Only Mode (no external publication)
{
  plugins: {
    sequence_detector: {
      selector: "app/messages/**",
      stats_interval_secs: 120
      // No stats_key - stats only appear in logs
    }
  }
}
