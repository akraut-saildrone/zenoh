// ============================================================================
// Full zenohd Configuration Example
// ============================================================================

/*
// This shows the plugin integrated into a complete zenohd config:
{
  // Zenoh configuration
  mode: "router",

  // Listen on all interfaces
  listen: {
    endpoints: ["tcp/0.0.0.0:7447"]
  },

  // Plugin configuration
  plugins: {
    // Sequence detector plugin
    sequence_detector: {
      selector: "sensors/**/data",
      stats_interval_secs: 60,
      stats_key: "admin/sequence_stats"
    },

    // REST API plugin (optional, useful for debugging)
    rest: {
      http_port: 8000
    },

    // Storage manager (optional, for persistence)
    storage_manager: {
      volumes: {}
    }
  },

  // Logging configuration
  logging: {
    // Set to "debug" to see all in-sequence messages
    // Set to "info" to see anomalies and periodic stats
    // Set to "warn" to only see problems
    level: "info"
  }
}
*/

// ============================================================================
// Integration with Other Zenoh Features
// ============================================================================

/*
// Example: Sequence Detection + Storage + REST API
{
  mode: "router",

  plugins: {
    // Monitor sequences
    sequence_detector: {
      selector: "sensors/**",
      stats_interval_secs: 60,
      stats_key: "admin/seq_stats"
    },

    // Store stats for historical analysis
    storage_manager: {
      volumes: {
        seq_stats: {
          backend: "memory",
          paths: ["admin/seq_stats"]
        }
      }
    },

    // Query via REST API
    rest: {
      http_port: 8000
    }
  }
}

// Then query stats with:
//   curl http://localhost:8000/admin/seq_stats
*/
