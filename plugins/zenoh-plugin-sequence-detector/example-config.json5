// Example zenohd configuration with sequence-detector plugin
//
// Usage:
//   zenohd --config example-config.json5
//
// This configuration demonstrates various plugin settings for different use cases.

{
  // Basic Example: Monitor all messages under "sensors/" with default settings
  plugins: {
    sequence_detector: {
      // Key expression pattern to monitor (supports wildcards)
      selector: "sensors/**/data",

      // Optional: How often to log statistics (seconds)
      // Default: 60 seconds
      stats_interval_secs: 30,

      // Optional: Publish statistics to this key
      // If omitted, stats are only logged to console/file
      stats_key: "admin/sequence/stats"
    }
  }
}

